config_version=5

[application]

config/name="jeremy rolling 2d"
run/main_scene="uid://dp0lgsqsc5uj8"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/show_image=false
boot_splash/use_filter=false

[autoload]

World1BGM="*uid://dwsqtq4kag3fx"
SaveManager="*uid://c7p3buhqaimv0"
